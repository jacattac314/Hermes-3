# Optional repo-local overrides. Prefer putting real secrets in ~/.hermes/.env.

# Local model selection. Used only if this exact id appears in /v1/models.
HERMES2_LOCAL_MODEL=

# Optional local base URL override.
HERMES2_LOCAL_BASE_URL=http://127.0.0.1:1234/v1

# Cloud provider keys. The runner checks whether these are set, but does not
# require them for local-first workflows.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local OpenAI-compatible runtimes usually do not require a real key.
LMSTUDIO_API_KEY=local
OLLAMA_API_KEY=local
