# Optional repo-local overrides. Prefer putting real secrets in ~/.hermes/.env.

# Local model selection. Used only if this exact id appears in /v1/models.
HERMES2_LOCAL_MODEL=

# Optional local base URL override.
HERMES2_LOCAL_BASE_URL=http://127.0.0.1:1234/v1

# Cloud provider keys. The runner checks whether these are set, but does not
# require them for local-first workflows.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Local OpenAI-compatible runtimes usually do not require a real key.
LMSTUDIO_API_KEY=local
OLLAMA_API_KEY=local

# Microsoft Teams Outgoing Webhook HMAC secret. Paste the security token that
# Teams shows when creating the outgoing webhook. Store the real value in
# ~/.hermes/.env, not in this template.
HERMES2_TEAMS_OUTGOING_SECRET=

# Android/mobile PWA access. Set HERMES2_MOBILE_TOKEN in ~/.hermes/.env to
# require the same token from Android before chat, tools, runs, and reports work.
HERMES2_MOBILE_TOKEN=

# Optional ntfy workflow-completion notifications for Android. Use a private
# topic value and store it only in ~/.hermes/.env.
HERMES2_NTFY_TOPIC=
HERMES2_NTFY_TOKEN=
